# Standalone frontend (আলাদা রিপোতে কপি করলে এই ফাইলটা `frontend/.env.local` এ নাম বদলে ব্যবহার করুন)
#
# --- Client (ব্রাউজারে যাবে — build সময় embed হয়; Docker/Coolify এ বদলালে web ইমেজ rebuild করতে হবে)
# পাবলিক API বেস; axios পাথগুলো এর সাপেক্ষে — শেষে অবশ্যই /v1
NEXT_PUBLIC_API_URL=http://localhost:5000/v1
# কিছু রাউটে optional হেডার (খালি রাখলে চলবে যদি API না চায়)
NEXT_PUBLIC_APP_KEY=

# --- Server-only (NextAuth / Auth.js v5 — ক্লায়েন্ট বান্ডেলে যাবে না)
# Server-side API base URL (Docker/Coolify এ internal network URL দিন; না দিলে NEXT_PUBLIC_API_URL fallback হবে)
API_INTERNAL_URL=http://api:5000/v1
# openssl rand -base64 32
AUTH_SECRET=
# ড্যাশবোর্ড যে পাবলিক URL এ খোলে (https সহ); Coolify এ আপনার ওয়েব ডোমেইন
AUTH_URL=http://localhost:3000
