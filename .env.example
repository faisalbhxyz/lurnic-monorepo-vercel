APP_PORT=5000
# Local: debug. Production: omit or set `release` (default is release when unset).
GIN_MODE=debug
# Optional: comma-separated trusted proxy IPs/CIDRs for X-Forwarded-For (Docker/reverse proxy).
# Default: loopback + RFC1918. Use `none` to trust only RemoteAddr (no forwarded headers).
# GIN_TRUSTED_PROXIES=

# Sentry (Error Monitoring)
# Create/rotate this in Sentry project settings (Client Keys)
SENTRY_DSN=
# Optional overrides
SENTRY_ENVIRONMENT=development
# 0..1 (0 disables tracing)
SENTRY_TRACES_SAMPLE_RATE=0

# Local-only debug routes (disabled by default)
ENABLE_DEBUG_ROUTES=false

# Goose / GORM (MySQL)
GOOSE_DRIVER=mysql
# Use ONE DSN for how you run the API:
# - Default docker-compose.yaml: external / third-party MySQL (Coolify, RDS, managed host):
GOOSE_DBSTRING=user:password@tcp(your-db-host.example.com:3306)/lurnic?charset=utf8mb4&parseTime=True&loc=UTC
# - Local `go run` + MySQL on your machine:
# GOOSE_DBSTRING=root:@tcp(127.0.0.1:3306)/dashlearn_local?charset=utf8mb4&parseTime=True&loc=Local
# - Docker Compose WITH optional bundled MySQL (`docker compose -f docker-compose.yaml -f docker-compose.mysql.yaml ...`):
# GOOSE_DBSTRING=lurnic:lurnic_local_dev@tcp(mysql:3306)/lurnic?charset=utf8mb4&parseTime=True&loc=UTC
# If you change MYSQL_PASSWORD or database name (bundled mysql file), set GOOSE_DBSTRING to match.
# GORM slow-query log threshold (ms). Default 1000; lower e.g. 200 for local fast DB.
# GORM_SLOW_SQL_MS=1000

# Auth (required; docker-compose also requires JWT_SECRET for variable substitution)
JWT_SECRET=replace_me_with_a_long_random_secret

# Optional: Vercel Cron hits GET /v1/internal/cron/publish-scheduled with Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Cloudflare R2 (S3-compatible) Object Storage (optional)
# Public delivery base URL (usually a custom domain routed to R2), without trailing slash.
R2_PUBLIC_BASE_URL=
# R2 account id (used to build the S3 endpoint: https://<accountid>.r2.cloudflarestorage.com)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Optional prefix inside the bucket (e.g. "uploads"). Leave empty to store at bucket root.
R2_UPLOAD_PREFIX=
# Optional override for request signing region; default is "auto".
R2_REGION=auto

# --- Docker Compose + Next.js dashboard (see docker-compose.yaml)
# Frontend-only env template: frontend/.env.example (আলাদা রিপোতে শুধু ওইগুলো লাগে)
# Optional: only when using docker-compose.mysql.yaml (bundled MySQL container)
MYSQL_DATABASE=lurnic
MYSQL_USER=lurnic
MYSQL_PASSWORD=lurnic_local_dev
MYSQL_ROOT_PASSWORD=lurnic_root_local_only
#
# Coolify checklist (set in the UI; no repo `.env` file required):
# - Domains: API → port 5000, Web → port 3000
# - NEXT_PUBLIC_API_URL = https://<api-host>/v1   (must end with /v1; rebuild `web` after changes)
# - AUTH_URL = https://<dashboard-host>
# - AUTH_SECRET, JWT_SECRET = strong random strings
# - GOOSE_DBSTRING = must match your DB (bundled defaults below, or your external DSN)
# - Optional: BUILD_SOURCE_CONTEXT=https://github.com/org/repo.git#master if build cannot see `frontend/`
# - Production: change MYSQL_* and GOOSE_DBSTRING; consider GIN_MODE=release (compose defaults to release if unset)
BUILD_SOURCE_CONTEXT=.
# Public API base URL for the browser — must end with /v1 (axios paths are relative to this).
NEXT_PUBLIC_API_URL=http://localhost:5000/v1
# Optional header some routes expect
NEXT_PUBLIC_APP_KEY=
# Server-side API base URL (NextAuth / server actions). In Docker Compose / Coolify, keep internal:
#   http://api:5000/v1
# For non-Docker (Vercel, etc.), you can omit and it will fall back to NEXT_PUBLIC_API_URL.
API_INTERNAL_URL=http://api:5000/v1
# NextAuth — required for `web` (docker compose). Production: openssl rand -base64 32
AUTH_SECRET=local_dev_only_change_me_use_strong_random_in_production
# Public URL of the dashboard (must match what users open in the browser, incl. https)
AUTH_URL=http://localhost:3000
# Host ports when using docker compose (defaults 5000 / 3000)
API_PUBLISH_PORT=5000
WEB_PUBLISH_PORT=3000
