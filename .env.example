APP_PORT=5000
GIN_MODE=debug

# Sentry (Error Monitoring)
# Create/rotate this in Sentry project settings (Client Keys)
SENTRY_DSN=
# Optional overrides
SENTRY_ENVIRONMENT=development
# 0..1 (0 disables tracing)
SENTRY_TRACES_SAMPLE_RATE=0

# Local-only debug routes (disabled by default)
ENABLE_DEBUG_ROUTES=false

# Goose / GORM (MySQL)
GOOSE_DRIVER=mysql
GOOSE_DBSTRING=root:@tcp(127.0.0.1:3306)/dashlearn_local?charset=utf8mb4&parseTime=True&loc=Local

# Auth
JWT_SECRET=replace_me_with_a_long_random_secret

# Digital Ocean / Storage Configuration (optional)
DO_BUCKET_NAME=
DO_REGION=
DO_SECRET=
DO_ACCESS_KEY=
DO_UPLOAD_FOLDER=

# BUNNY CDN Configuration (optional)
BUNNY_STORAGE_ZONE=
BUNNY_STORAGE_HOSTNAME=
BUNNY_API_KEY=
BUNNY_UPLOAD_FOLDER=
BUNNY_PULL_ZONE=
